# Firebase Web App Config
# Get these from: Firebase Console → Project Settings → Your apps → Web app
# Project: traiga-auditor  |  https://console.firebase.google.com/project/traiga-auditor
#
# Steps:
#   1. Go to Firebase Console → Project Settings → General
#   2. Scroll to "Your apps" → click the web app (or Add app → Web)
#   3. Copy the firebaseConfig values below

VITE_FIREBASE_API_KEY=your-web-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=traiga-auditor.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=traiga-auditor
