# ── Google Sheets ─────────────────────────────────────────────────────────────
# Download your service-account key from Google Cloud Console and save the JSON
# file inside the backend/ directory (or set an absolute path below).
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Copy the Spreadsheet ID from your Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins (Vue dev server + Firebase domain)
CORS_ORIGINS=http://localhost:5173,https://your-project.web.app

# Residential proxy for WAF bypass (leave empty for direct crawl)
SCAN_PROXY_URL=
SCAN_PROXY_ONLY_FLAGGED=false
