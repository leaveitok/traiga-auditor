# ── Secrets — NEVER include in Docker image ───────────────────────────────────
service_account.json
*.json.key
.env
.env.*
!.env.example

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# ── Tests — not needed in production image ────────────────────────────────────
tests/

# ── Dev tooling ───────────────────────────────────────────────────────────────
.git/
.gitignore
Dockerfile
.dockerignore
*.md
