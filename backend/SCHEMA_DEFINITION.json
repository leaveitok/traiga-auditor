  "violation_template": {
    "description": "Shape of every violation record. cure_period_status and days_remaining are REQUIRED per project spec.",
    "fields": {
      "violation_id": {
        "type": "string",
        "description": "Stable hash of {city, asset_id, rule_id}."
      },
      "city": {
        "type": "string"
      },
      "domain": {
        "type": "string"
      },
      "asset_id": {
        "type": "string"
      },
      "vendor_id": {
        "type": "string"
      },
      "rule_id": {
        "type": "string"
      },
      "citation": {
        "type": "string"
      },
      "severity": {
        "type": "string",
        "enum": [
          "informational",
          "low",
          "medium",
          "high"
        ]
      },
      "first_observed_utc": {
        "type": "string",
        "format": "date-time"
      },
      "last_observed_utc": {
        "type": "string",
        "format": "date-time"
      },
      "cure_deadline_utc": {
        "type": "string",
        "format": "date-time",
        "description": "first_observed + 60 days."
      },
      "cure_period_status": {
        "type": "boolean",
        "description": "true while inside the active 60-day cure window."
      },
      "days_remaining": {
        "type": "integer",
        "minimum": 0,
        "maximum": 60
      },
      "status": {
        "type": "string",
        "enum": [
          "open",
          "in_cure",
          "cured",
          "expired"
        ]
      },
      "evidence": {
        "type": "object",
        "description": "Indicators that fired; URLs; no end-user PII."
      },
      "needs_human_review": {
        "type": "boolean",
        "default": true
      }
    },
    "required": [
      "violation_id",
      "city",
      "rule_id",
      "citation",
      "severity",
      "first_observed_utc",
      "cure_period_status",
      "days_remaining",
      "status"
    ]
  },
  "scorecard_schema": {
    "scan_cadence_hours": 24,
    "cure_period_days": 60,
    "score_start": 100,
    "severity_weights": {
      "informational": 0,
      "low": 5,
      "medium": 12,
      "high": 25
    },
    "in_cure_weight_multiplier": 0.5,
    "expired_weight_multiplier": 1.0,
    "bands": {
      "green": [
        90,
        100
      ],
      "amber": [
        70,
        89
      ],
      "red": [
        0,
        69
      ]
    },
    "row_fields": [
      "city",
      "jurisdiction",
      "domain",
      "ai_assets_detected",
      "traiga_status",
      "sb149_status",
      "open_violations",
      "min_days_remaining",
      "compliance_score",
      "band",
      "last_scanned_utc"
    ],
    "sort": {
      "by": "min_days_remaining",
      "order": "asc"
    }
  }
}