  "Compliance_Ruleset": {
    "Internal_Governance_Module": {
      "module_description": "RESERVED for future inline use against City-operated AI systems. Not evaluated by the external observer.",
      "enabled": false,
      "rules": [
        {
          "rule_id": "INT-NIST-GOVERN-01",
          "title": "AI inventory and governance ownership documented",
          "framework": "NIST AI RMF (Govern)",
          "citation": "NIST AI RMF 1.0 -- GOVERN function",
          "severity": "medium",
          "evaluator": "manual_attestation",
          "remediation": "Maintain an AI system inventory with assigned governance owner.",
          "status_default": "not_assessed"
        },
        {
          "rule_id": "INT-TRAIGA-SAFEHARBOR-01",
          "title": "Internal/adversarial testing program evidence",
          "framework": "HB 149 / TRAIGA safe harbor",
          "citation": "Tex. Bus. & Com. Code Ch. 552 (safe-harbor provisions)",
          "severity": "informational",
          "evaluator": "manual_attestation",
          "remediation": "Document red-team / adversarial testing to support good-faith defense.",
          "status_default": "not_assessed"
        }
      ]
    },
    "External_Transparency_Module": {
      "module_description": "Evaluated by the External Transparency Agent against publicly observable evidence only.",
      "enabled": true,
      "rules": [
        {
          "rule_id": "EXT-DISCLOSURE-PRESENCE-01",
          "title": "AI-interaction disclosure present",
          "framework": "HB 149 / TRAIGA",
          "citation": "Tex. Bus. & Com. Code 552.051",
          "applies_when": "ai_asset_detected",
          "severity": "high",
          "evaluator": "disclosure_presence",
          "pass_condition": "A statement that the user is interacting with an AI system is present in or adjacent to the asset.",
          "remediation": "Add a clear statement that the user is interacting with an AI system.",
          "status_default": "not_assessed"
        },
        {
          "rule_id": "EXT-DISCLOSURE-TIMING-02",
          "title": "Disclosure shown before or at time of interaction",
          "framework": "HB 149 / TRAIGA",
          "citation": "Tex. Bus. & Com. Code 552.051",
          "applies_when": "ai_asset_detected",
          "severity": "high",
          "evaluator": "disclosure_timing",
          "pass_condition": "Disclosure is visible before/at first interaction, not buried in footer-only links.",
          "remediation": "Surface the disclosure at the entry point of the AI asset.",
          "status_default": "not_assessed"
        },
        {
          "rule_id": "EXT-DISCLOSURE-CLARITY-03",
          "title": "Disclosure is clear, conspicuous, plain-language, no dark patterns",
          "framework": "HB 149 / TRAIGA",
          "citation": "Tex. Bus. & Com. Code 552.051",
          "applies_when": "ai_asset_detected",
          "severity": "medium",
          "evaluator": "disclosure_clarity",
          "pass_condition": "Disclosure language is plain, prominent, and not obscured by dark-pattern design.",
          "remediation": "Rewrite disclosure in plain language and increase prominence.",
          "status_default": "not_assessed"
        },
        {
          "rule_id": "EXT-PRIVACY-POLICY-04",
          "title": "Privacy policy linked, reachable, and addresses automated processing",
          "framework": "HB 149 / TRAIGA (transparency) + general privacy practice",
          "citation": "Tex. Bus. & Com. Code Ch. 552 (transparency objectives)",
          "applies_when": "ai_asset_detected",
          "severity": "medium",
          "evaluator": "privacy_policy_audit",
          "pass_condition": "A reachable privacy policy is linked from the asset context and references automated/AI processing.",
          "remediation": "Link a reachable privacy policy that addresses AI/automated processing.",
          "status_default": "not_assessed"
        },
        {
          "rule_id": "EXT-BIOMETRIC-VISIBILITY-05",
          "title": "Biometric capture notice/consent visible when biometric indicators present",
          "framework": "HB 149 / TRAIGA (biometric constraints)",
          "citation": "Tex. Bus. & Com. Code Ch. 552 (biometric provisions)",
          "applies_when": "biometric_indicator_detected",
          "severity": "high",
          "evaluator": "biometric_consent_visibility",
          "pass_condition": "Where biometric capture is indicated, notice/consent is surfaced to the user.",
          "remediation": "Surface biometric notice/consent; confirm lawful basis with counsel.",
          "status_default": "not_assessed"
        }
      ]
    }
