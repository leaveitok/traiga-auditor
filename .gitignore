# ── CRITICAL: Service Account Keys ───────────────────────────────────────────
# These files contain private keys and MUST NEVER be committed.
# If you accidentally commit a key, rotate it immediately in Google Cloud Console.
service_account.json
*service_account*.json
*.serviceaccount.json
firebase-adminsdk*.json
google-credentials*.json

# ── Environment Variables ─────────────────────────────────────────────────────
deploy/env.yaml
.env
.env.local
.env.*.local
# Keep .env.example committed — it documents required vars without real values
!.env.example

